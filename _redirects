# Cloudflare Pages serves /foo when requesting /foo.html by default and
# 301-redirects /foo.html -> /foo. Rules below cover only the cases that
# default behavior does not handle.

# Canonicalize trailing-slash variants on top-level pages
/about/         /about          301
/services/      /services       301
/results/       /results        301
/journal/       /journal        301
/membership/    /membership     301
/book/          /book           301
/contact/       /contact        301
/policies/      /policies       301
/privacy/       /privacy        301

# Legacy journal article slugs (had a `blog-` prefix that didn't match
# the canonical URL in the article's <link rel="canonical"> tag).
# Files were renamed; redirects preserve external links + indexed URLs.
/journal/blog-what-is-buccal-massage          /journal/what-is-buccal-massage           301
/journal/blog-tmj-relief-facial-massage       /journal/tmj-relief-facial-massage        301
/journal/blog-natural-alternatives-to-botox   /journal/natural-alternatives-to-botox    301
/journal/blog-how-breathing-shapes-your-face  /journal/how-breathing-shapes-your-face   301

# Homepage typo legacy — `-murray-utah` suffix that matched no file.
/journal/what-is-buccal-massage-murray-utah   /journal/what-is-buccal-massage           301
