# Cloudflare Pages serves /foo when requesting /foo.html by default and
# 301-redirects /foo.html -> /foo. Rules below cover only the cases that
# default behavior does not handle.

# Canonicalize trailing-slash variants on top-level pages
/about/         /about          301
/services/      /services       301
/results/       /results        301
/journal/       /journal        301
/membership/    /membership     301
/book/          /book           301
/contact/       /contact        301
/policies/      /policies       301
/privacy/       /privacy        301

# Legacy journal article slugs (had a `blog-` prefix that didn't match
# the canonical URL in the article's <link rel="canonical"> tag).
# Files were renamed; redirects preserve external links + indexed URLs.
# Pre-flattened to the current slug to avoid 301→301 chains.
/journal/blog-what-is-buccal-massage          /journal/what-is-buccal-manipulation       301
/journal/blog-tmj-relief-facial-massage       /journal/tmj-relief-facial-release         301
/journal/blog-natural-alternatives-to-botox   /journal/hands-first-facial-alternatives   301
/journal/blog-how-breathing-shapes-your-face  /journal/how-breathing-shapes-your-face    301

# Renamed journal article: the slug originally named a prescription drug
# which tripped Google Ads "Restricted drug terms" policy. New slug uses
# generic language.
/journal/natural-alternatives-to-botox        /journal/hands-first-facial-alternatives   301

# Homepage typo legacy — `-murray-utah` suffix that matched no file.
# Flattened straight to the current slug.
/journal/what-is-buccal-massage-murray-utah   /journal/what-is-buccal-manipulation       301

# Utah Master Esthetician scope compliance (2026-05-19): "massage" rebranded
# to "release" across the site. Preserves external links + indexed URLs
# pointing at the old massage-suffixed slugs.
# The "buccal massage" slug now jumps straight to the current "manipulation"
# slug (see below) to avoid a 301 chain.
/journal/what-is-buccal-massage               /journal/what-is-buccal-manipulation       301
/journal/tmj-relief-facial-massage            /journal/tmj-relief-facial-release         301
/services/restorative-buccal-massage          /services/restorative-buccal-release       301

# Terminology shift (2026-05-30): "buccal release" rebranded to "buccal
# manipulation" on the journal article. Service slug stays. Preserves
# external links, social shares, Google-indexed URLs, and any Google Ads
# landing-page URLs that still point at the old slug.
/journal/what-is-buccal-release               /journal/what-is-buccal-manipulation       301

# 2026-07-03: consolidate duplicate buccal-facial + about pages to their canonical
# (fixes GSC "Duplicate, Google chose different canonical than user")
/restorative-facial                           /services/restorative-buccal-release       301
