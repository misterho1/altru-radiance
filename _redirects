# Cloudflare Pages serves /foo when requesting /foo.html by default and
# 301-redirects /foo.html -> /foo. Rules below cover only the cases that
# default behavior does not handle.

# Buccal massage card on the homepage uses the SEO slug; the actual file is
# /journal/blog-what-is-buccal-massage. 301 — the file rename is permanent.
/journal/what-is-buccal-massage-murray-utah        /journal/blog-what-is-buccal-massage    301

# Articles linked from the homepage but not yet written. Soft 302 to the
# Journal index so visitors don't see a 404 in the meantime. When the article
# is published at the matching slug, delete the line — the new page will
# serve directly. DO NOT promote these to 301 (Google would index /journal
# as the canonical for the unwritten slug, blocking the future article).
/journal/lymphatic-drainage-benefits-salt-lake-city /journal 302
/journal/myofascial-release-facial-salt-lake-city   /journal 302

# Canonicalize trailing-slash variants on top-level pages
/about/         /about          301
/services/      /services       301
/results/       /results        301
/journal/       /journal        301
/membership/    /membership     301
/book/          /book           301
/contact/       /contact        301
/policies/      /policies       301
/privacy/       /privacy        301
